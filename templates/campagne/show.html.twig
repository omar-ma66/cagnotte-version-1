{#  Calcule des variables #}

{% set objectif_total = campagne.objectif %}
{% set somme_total = 0 %}

{% for paiement in paiements %}
	{% set somme_total = somme_total + paiement.montant %}
{% endfor %}

{% set pourcentage = 100 * somme_total / objectif_total %}

{% if pourcentage > 100 %}
	{% set pourcentage = 100 %}
{% endif %}


{# ##################### #}


{%  extends "base.html.twig" %}
{% block title %}
	Cagnot' Potes
{% endblock %}

{% block body %}
	{{ include('_partials/_nav_barre.html.twig') }}
	<div class="bg-gray-50 text-gray-800 antialiased">


		<div id="sidenav-overlay" class="fixed inset-0 bg-black/40 z-50 hidden transition-opacity duration-300"></div>
		<div id="nav-mobile" class="fixed top-0 left-0 bottom-0 w-64 bg-white z-50 shadow-xl transform -translate-x-full transition-transform duration-300 ease-in-out p-6">
			<div class="flex justify-between items-center mb-8">
				<span class="text-xl font-medium text-gray-700">Navigation</span>
				<button id="menu-close" class="text-gray-500 hover:text-gray-800">
					<i class="material-icons">close</i>
				</button>
			</div>
			<ul class="space-y-4">
				<li>
					<a href="create.html" class="block text-center bg-pink-500 hover:bg-pink-600 text-white px-4 py-3 rounded shadow transition uppercase text-sm font-medium tracking-wider">
						Créer une campagne
					</a>
				</li>
			</ul>
		</div>

		<div class="relative h-[450px] bg-fixed bg-center bg-no-repeat bg-cover flex items-center justify-center text-white" style="background-image: url('../assets/images/8.jpg');">
			<div class="absolute inset-0 bg-black/40"></div>
			<div class="relative z-10 text-center px-4 max-w-4xl">
				<h1 class="text-4xl md:text-5xl font-light mb-4">{{campagne.titre}}</h1>
				<h5 class="text-xl font-light text-gray-200">- Organisée par :
					{{ campagne.nom }}-</h5>
			</div>
		</div>

		<section class="max-w-4xl mx-auto px-4 mt-8">
			<div class="w-full bg-gray-200 rounded-full h-6 overflow-hidden relative shadow-inner">
				<div style="width:{{ pourcentage }}%" class="bg-teal-500 h-6 rounded-full flex items-center justify-center transition-all duration-500" style="width: 70%">
					<span style="width:{{ pourcentage }}%" class="text-white text-center text-xs font-medium">{{ pourcentage}}%
					</span>
				</div>
			</div>
		</section>

		<div class="max-w-4xl mx-auto px-4 py-12">

			<div class="flex justify-center mb-12">
				<div class="w-full lg:w-10/12 bg-white rounded-lg shadow-md border border-gray-100 p-6">
					<div class="flex justify-center md:grid-cols-2 gap-6 items-center">


						{% if somme_total < objectif_total %}
							<div>
								<a href="{{ path('app_paiement_new',{id:campagne.id} )}}" class="block text-center bg-pink-500 hover:bg-pink-600 text-white font-medium py-3 px-6 rounded shadow transition duration-200 text-lg">
									je veux Participer
								</a>
							</div>
						{% else %}
							<div>
								<a href="{{ path('app_campagne_index')}}" class="block text-center bg-pink-500 hover:bg-pink-600 text-white font-medium py-3 px-6 rounded shadow transition duration-200 text-lg">
									La campagne est terminé merci pour votre participation
								</a>
							</div>

						{% endif %}


					</div>
				</div>
			</div>

			<div class="text-center mb-8">
				<h4 class="text-3xl font-medium text-gray-700">A propos de la campagne</h4>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-2xl mx-auto mb-12">
				<div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100 text-center flex flex-col items-center">
					<div class="w-16 h-16 rounded-full bg-teal-50 flex items-center justify-center shadow-sm mb-3">
						<i class="material-icons text-teal-600 text-3xl">person</i>
					</div>
					<h3 class="text-4xl font-bold text-gray-700 mb-1">{{participants|length }}</h3>
					<p class="text-gray-500 font-light">Participants</p>
				</div>

				<div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100 text-center flex flex-col items-center">
					<div class="w-16 h-16 rounded-full bg-teal-50 flex items-center justify-center shadow-sm mb-3">
						<i class="material-icons text-teal-600 text-3xl">redeem</i>
					</div>
					{% set somme =  0 %}
					{% for paiement in paiements %}
						{% set somme = somme + paiement.montant %}
					{% endfor %}
					<h3 class="text-4xl font-bold text-gray-700 mb-1">{{ somme }}</h3>
					<p class="text-gray-500 font-light">euros récoltés</p>
				</div>
			</div>
			{# #################################################################################################################################################### #}

			{#              Ajuster le formulaire  formtype      #}
			{# #################################################################################################################################################### #}

				<div class="bg-white rounded-lg shadow-md border border-gray-100 p-6 md:p-8 mb-12"> <form class="grid grid-cols-1 gap-6">
					<div>
						<label for="description" class="block text-sm font-medium text-gray-500 mb-1">Description</label>
						<textarea id="description" readonly class="w-full min-h-[100px] border border-gray-200 rounded p-3 bg-gray-50 text-gray-600 focus:outline-none focus:ring-1 focus:ring-gray-300 resize-y">{{ campagne.contenu}}</textarea>
					</div>

					<div class="md:w-1/2">
						<label for="goal" class="block text-sm font-medium text-gray-500 mb-1">objectif</label>
						<input id="goal" type="number" readonly value="{{campagne.objectif}}" class="w-full border border-gray-200 rounded p-3 bg-gray-50 text-gray-600 focus:outline-none">
					</div>
				</form>
			</div>
			{# #################################################################################################################################################### #}

			<div class="mb-12">
				<div class="text-center mb-6">
					<h4 class="text-3xl font-medium text-gray-700">Liste des participants</h4>
				</div>
				<div class="bg-white rounded-lg shadow overflow-hidden border border-gray-100">
					<table class="w-full text-left border-collapse">
						<thead>
							<tr class="bg-gray-100 text-gray-600 uppercase text-xs tracking-wider border-b border-gray-200">
								<th class="py-4 px-6 font-semibold">Email</th>
								<th class="py-4 px-6 font-semibold">Participation</th>
							</tr>
						</thead>

						<tbody class="divide-y divide-gray-100 text-gray-700">

							{% for paiement in paiements %}
								<tr>
									<td class="py-4 px-6">{{ paiement.participant.email}}
									</td>
									<td class="py-4 px-6">{{ paiement.montant}}
										€
									</td>
								</tr>

							{%  endfor %}
						</tbody>
					</table>
				</div>
			</div>

		</div>

		<div class="relative h-[300px] bg-fixed bg-center bg-no-repeat bg-cover flex items-center justify-center text-white" style="background-image: url('../assets/images/10.jpg');">
			<div class="absolute inset-0 bg-black/40"></div>
			<div class="relative z-10 text-center px-4 max-w-4xl">
				<h4 class="text-2xl md:text-3xl font-light">Une campagne pensée pour vous<br>et pour toutes les occasions</h4>
			</div>
		</div>


		{{ include ('_partials/_footer.html.twig') }}


		{# ############################################################################################################################################################# #}
		{# ############################################################################################################################################################# #}
		{#                                                                 JAVASCRYPT                                                                                    #}
		{# ############################################################################################################################################################# #}
		{# ############################################################################################################################################################# #}
			<script>
const trigger = document.getElementById('menu-trigger');
const closeBtn = document.getElementById('menu-close');
const sidenav = document.getElementById('nav-mobile');
const overlay = document.getElementById('sidenav-overlay');

trigger.addEventListener('click', () => {
sidenav.classList.remove('-translate-x-full');
overlay.classList.remove('hidden');
});

const closeMenu = () => {
sidenav.classList.add('-translate-x-full');
overlay.classList.add('hidden');
};

closeBtn.addEventListener('click', closeMenu);
overlay.addEventListener('click', closeMenu);
	</script>
</div>{%  endblock %}
