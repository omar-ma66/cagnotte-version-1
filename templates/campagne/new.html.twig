 {% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.js"></script>
    <script>
        (function() {
            let editor = null;
            const EDITOR_ID = "{{ form.contenu.vars.id }}";

            function destroyEditor() {
                if (!editor) return;
                try {
                    editor.toTextArea();
                    document.querySelectorAll('.editor-preview-side, .CodeMirror, .editor-toolbar, .editor-statusbar').forEach(el => {
                        if (el.parentNode) el.parentNode.removeChild(el);
                    });
                    editor = null;
                    const textarea = document.getElementById(EDITOR_ID);
                    if (textarea) {
                        textarea.style.display = 'block';
                        textarea.classList.remove('simplemde-ready');
                    }
                } catch(e) {
                    console.warn('Erreur destruction SimpleMDE:', e);
                    editor = null;
                }
            }

            function initEditor() {
                const textarea = document.getElementById(EDITOR_ID);
                if (!textarea) return;
                
                if (textarea.classList.contains('simplemde-ready')) return;

                try {
                    editor = new SimpleMDE({ 
                        element: textarea,
                        spellChecker: false,
                        status: false,
                        placeholder: "Décrivez à vos amis pourquoi vous faites une campagne..."
                    });

                    // 🌟 LA SYNCHRONISATION EN TEMPS RÉEL POUR LA BASE DE DONNÉES :
                    editor.codemirror.on("change", function() {
                        textarea.value = editor.value();
                    });

                    textarea.classList.add('simplemde-ready');
                } catch(e) {
                    console.error('Erreur init SimpleMDE:', e);
                }

                setupMobileMenu();
            }

            function setupMobileMenu() {
                const trigger = document.getElementById('menu-trigger');
                const closeBtn = document.getElementById('menu-close');
                const sidenav = document.getElementById('nav-mobile');
                const overlay = document.getElementById('sidenav-overlay');

                if (trigger && sidenav && overlay) {
                    trigger.onclick = () => { sidenav.classList.remove('-translate-x-full'); overlay.classList.remove('hidden'); };
                    if (closeBtn) closeBtn.onclick = () => { sidenav.classList.add('-translate-x-full'); overlay.classList.add('hidden'); };
                    overlay.onclick = () => { sidenav.classList.add('-translate-x-full'); overlay.classList.add('hidden'); };
                }
            }

            // Événements Turbo de nettoyage de cache uniquement
            document.addEventListener("turbo:before-cache", destroyEditor);
            
            // Initialisation de l'éditeur au chargement initial et via Turbo
            document.addEventListener("DOMContentLoaded", initEditor);
            document.addEventListener("turbo:load", initEditor);
        })();
    </script>
{% endblock %}