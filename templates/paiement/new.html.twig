{% extends 'base.html.twig' %}


{% block title %}
	Cagnot'potes
{% endblock %}


{% block body %}
	{# ###################################################################################### #}


	{% include '_partials/_nav_barre.html.twig' %}
	{# ###################################################################################### #}


	<div class="relative h-[400px] flex items-center justify-center bg-fixed bg-cover bg-center" style="background-image: url('../assets/images/8.jpg');">
		<div class="absolute inset-0 bg-black/40"></div>

		<div class="relative z-10 text-center px-4 max-w-4xl">
			<h1 class="text-4xl md:text-5xl font-light text-white mb-4">{{ campagnes.titre }}</h1>
			<h5 class="text-lg md:text-xl font-light text-white/90">- Organisée par :
				{{ campagnes.nom }}
				-</h5>
		</div>
	</div>

	<div class="max-w-7xl mx-auto px-4 py-12">
		<div class="text-center mb-8">
			<h4 class="text-2xl md:text-3xl font-semibold text-gray-800">Participez en quelques secondes</h4>
		</div>

		<div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden max-w-3xl mx-auto">
			<div class="p-6 sm:p-10">


				{{ form_start(form, {'attr': {'class': 'max-w-2xl mx-auto p-6 bg-white rounded-lg shadow-sm'}}) }}

				<h5 class="text-xl font-semibold text-center text-gray-800 mb-8">Votre identité</h5>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20">

					<div class="relative z-0 w-full group">
						{{ form_widget(form.participant.email, {'attr': {
                'class': 'block py-2.5 px-0 w-full text-sm text-gray-950 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-pink-500 peer',
                'placeholder': ' '
            }}) }}
						{{ form_label(form.participant.email, null, {'label_attr': {
                'class': 'absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6 peer-focus:font-medium peer-focus:start-0 peer-focus:text-pink-500'
            }}) }}
					</div>


					<div class="relative z-0 w-full group">
						{{ form_widget(form.participant.nom, {'attr': {
                'class': 'block py-2.5 px-0 w-full text-sm text-gray-950 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-pink-500 peer',
                'placeholder': ' '
            }}) }}
						{{ form_label(form.participant.nom, null, {'label_attr': {
                'class': 'absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6 peer-focus:font-medium peer-focus:start-0 peer-focus:text-pink-500'
            }}) }}
					</div>


					<div class="relative z-0 w-full group ">
						{{ form_widget(form.montant, {'attr': {
                'class': 'block py-2.5 px-0 w-full text-sm text-gray-950 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-pink-500 peer',
                'placeholder': ' '
            }}) }}
						{{ form_label(form.montant, null, {'label_attr': {
                'class': 'absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6 peer-focus:font-medium peer-focus:start-0 peer-focus:text-pink-500'
            }}) }}
					</div>

				</div>


				<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8 pt-8 ">

					<a href="#!" class="block text-center bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium py-3 px-6 rounded transition duration-200 text-lg order-2 md:order-1">
						Annuler
					</a>

					<button type="submit" name="action" class="flex items-center justify-center bg-pink-500 hover:bg-pink-600 text-white font-medium py-3 px-6 rounded shadow transition duration-200 text-lg order-1 md:order-2">
						<span>Participer</span>

					</button>

				</div>

				{{ form_end(form) }}

			</div>

		</div>
	</div>
</div>

<div class="bg-gray-50 py-16">
	<div class="max-w-7xl mx-auto px-4">
		<div class="text-center mb-12">
			<h4 class="text-2xl md:text-3xl font-semibold text-gray-800">Comment ça marche ?</h4>
		</div>


		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">

			<div class="text-center">
				<div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white shadow border border-gray-100 mb-4">
					<i class="material-icons text-teal-500 text-3xl">edit_note</i>
				</div>
				<h4 class="text-xl font-medium mb-2">Créez</h4>
				<p class="text-gray-500 font-light max-w-xs mx-auto">et personnalisez votre campagne commune en 30 secondes !</p>
			</div>

			<div class="text-center">
				<div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white shadow border border-gray-100 mb-4">
					<i class="material-icons text-teal-500 text-3xl">people</i>
				</div>
				<h4 class="text-xl font-medium mb-2">Invitez</h4>
				<p class="text-gray-500 font-light max-w-xs mx-auto">vos amis en utilisant les réseaux sociaux, mail, etc.</p>
			</div>

			<div class="text-center">
				<div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white shadow border border-gray-100 mb-4">
					<i class="material-icons text-teal-500 text-3xl">shopping_cart</i>
				</div>
				<h4 class="text-xl font-medium mb-2">Collectez</h4>
				<p class="text-gray-500 font-light max-w-xs mx-auto">et utilisez l'argent comme bon vous semble avec vos amis.</p>
			</div>
		</div>


	</div>
</div>


{# ###################################################################################### #}


{# ###################################################################################### #}

<!--JavaScript at end of body for optimized loading--><script type="text/javascript" src="../assets//js/materialize.min.js"> </script>
<!--Javascript Markdown editor-->
<script src="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.js"></script>
<!--Init & custom scripts-->
<script type="text/javascript" src="../assets//js/scripts.js"></script>
{{ include ('_partials/_footer.html.twig')}}{% endblock %}
